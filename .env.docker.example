FRONTEND_PORT=8080
BACKEND_PORT=8000

# Cambia IP_O_DOMINIO_DEL_SERVIDOR por la IP o dominio real donde corre Portainer.
PUBLIC_API_BASE_URL=http://IP_O_DOMINIO_DEL_SERVIDOR:8000/api/v1

# Para demo permite que el frontend público consuma el backend.
# Puedes restringirlo luego a tu dominio, por ejemplo:
# BACKEND_CORS_REGEX=^https?://tudominio\.com(:8080)?$
BACKEND_CORS_REGEX=^https?://.*$
